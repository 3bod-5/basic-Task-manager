<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Edit Task</title>

    <style>
        body {
            font-family: Arial;
            background: #f4f6f9;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .form-container {
            background: white;
            padding: 20px;
            width: 400px;
            border-radius: 10px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }

        input, select, textarea {
            width: 100%;
            padding: 10px;
            margin: 10px 0;
        }

        button {
            width: 100%;
            padding: 10px;
            background: #007bff;
            color: white;
            border: none;
            cursor: pointer;
        }
    </style>
</head>
<body>

<div class="form-container">
    <h2>Edit Task</h2>

    <form action="/dashboard/update-task/<%= task._id %>" method="POST">

        <input type="text" name="task" value="<%= task.task %>" required>

        <textarea name="description" required><%= task.description %></textarea>

        <select name="status">
            <option value="In-Progress" <%= task.status === 'In-Progress' ? 'selected' : '' %>>In-Progress</option>
            <option value="Finished" <%= task.status === 'Finished' ? 'selected' : '' %>>Finished</option>
            <option value="Out-Of-Date" <%= task.status === 'Out-Of-Date' ? 'selected' : '' %>>Out-Of-Date</option>
        </select>

        <button type="submit">Update Task</button>
    </form>
</div>

</body>
</html>